{
  "manifest_version": 3,
  "name": "HTML to Figma Capture",
  "version": "1.0.0",
  "description": "一键捕获当前页面 HTML 并转换为 Figma 设计格式，自动复制到剪切板",
  "permissions": [
    "activeTab",
    "scripting",
    "clipboardWrite",
    "notifications"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "HTML to Figma - 点击捕获"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["capture.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
